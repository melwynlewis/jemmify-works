---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

const recentPosts = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section id="resources" class="py-24 bg-[#3b3b3b] text-white overflow-hidden" data-ps="src/components/home/BlogPreview.astro:ao1ecw">
  <div class="container mx-auto px-4" data-ps="src/components/home/BlogPreview.astro:ry2snt">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6" data-ps="src/components/home/BlogPreview.astro:ry2snu">
      <div class="max-w-2xl" data-ps="src/components/home/BlogPreview.astro:ry2snv">
        <h2 class="text-3xl md:text-5xl font-bold mb-4" data-ps="src/components/home/BlogPreview.astro:ozcmfr">Resources for Growth</h2>
        <p class="text-gray-400 text-lg" data-ps="src/components/home/BlogPreview.astro:pxz3kc">Insights, guides, and strategies to help your business shine.</p>
      </div>
      <a href="/blog" class="group flex items-center gap-2 text-[#bcc341] hover:text-[#de1862] transition-colors font-semibold" data-ps="src/components/home/BlogPreview.astro:x1x0a2">
        View all resources
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/components/home/BlogPreview.astro:ry2snw">
      {recentPosts.map((post) => (
        <a href={`/blog/${post.slug}`} class="group flex flex-col bg-[#2a2a2a] rounded-2xl overflow-hidden border border-gray-800 hover:border-[#2d58a5] transition-all duration-300" data-ps="src/components/home/BlogPreview.astro:x1x0a3">
          <div class="aspect-video overflow-hidden" data-ps="src/components/home/BlogPreview.astro:ry2snx">
            <img 
              src={post.data.image} 
              alt={post.data.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" data-ps="src/components/home/BlogPreview.astro:1x65zh" />
          </div>
          <div class="p-6 flex flex-col flex-grow" data-ps="src/components/home/BlogPreview.astro:ry2sny">
            <div class="flex items-center gap-3 mb-4" data-ps="src/components/home/BlogPreview.astro:ry2snz">
              <span class="text-xs font-bold uppercase tracking-wider text-[#de1862]" data-ps="src/components/home/BlogPreview.astro:eopup0">{post.data.category || 'Insights'}</span>
              <span class="w-1 h-1 rounded-full bg-gray-600" data-ps="src/components/home/BlogPreview.astro:eopup1"></span>
              <time datetime={post.data.pubDate.toISOString()} class="text-xs text-gray-400">
                {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </div>
            <h3 class="text-xl font-bold mb-3 group-hover:text-[#2d58a5] transition-colors line-clamp-2" data-ps="src/components/home/BlogPreview.astro:vdcibs">{post.data.title}</h3>
            <p class="text-gray-400 text-sm mb-6 line-clamp-3" data-ps="src/components/home/BlogPreview.astro:pxz3kd">{post.data.description}</p>
            <div class="mt-auto pt-4 border-t border-gray-800 flex items-center gap-2 text-sm font-medium text-white" data-ps="src/components/home/BlogPreview.astro:ry2so0">
              Read article
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all"><path d="m9 18 6-6-6-6"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
