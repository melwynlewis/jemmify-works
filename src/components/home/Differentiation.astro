---
---
<section id="differentiation" class="py-24 md:py-32 bg-zinc-50 px-6 overflow-hidden" data-ps="src/components/home/Differentiation.astro:main">
  <div class="max-w-7xl mx-auto" data-ps="src/components/home/Differentiation.astro:container">
    <!-- Header -->
    <div class="text-center mb-20 reveal" data-ps="src/components/home/Differentiation.astro:header">
      <h2 class="text-4xl md:text-5xl font-bold text-zinc-900 mb-6" data-ps="src/components/home/Differentiation.astro:title">Why Jemmify Works is Different</h2>
      <p class="text-xl text-zinc-600 max-w-3xl mx-auto leading-relaxed" data-ps="src/components/home/Differentiation.astro:subtitle">
        Most agencies build websites. We build conversion-focused digital systems designed to generate measurable business outcomes.
      </p>
    </div>

    <!-- Comparison Block -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-24 reveal reveal-delay-1" data-ps="src/components/home/Differentiation.astro:comparison">
      <!-- Typical Agency -->
      <div class="bg-white p-8 md:p-12 rounded-3xl border border-zinc-200" data-ps="src/components/home/Differentiation.astro:typical-agency">
        <h3 class="text-2xl font-bold text-zinc-600 mb-8 uppercase tracking-wider" data-ps="src/components/home/Differentiation.astro:typical-title">Typical Web Agency</h3>
        <ul class="space-y-6" data-ps="src/components/home/Differentiation.astro:typical-list">
          {[
            "Template-based designs",
            "Focus on pages, not outcomes",
            "Design-first approach",
            "No performance tracking",
            "One-time delivery mindset"
          ].map((item) => (
            <li class="flex items-start gap-4 text-zinc-500" data-ps="src/components/home/Differentiation.astro:typical-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-600 shrink-0 mt-0.5"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
              <span class="text-lg" data-ps="src/components/home/Differentiation.astro:typical-text">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Jemmify Works -->
      <div class="bg-primary p-8 md:p-12 rounded-3xl border border-white/10 text-white shadow-2xl shadow-emerald/10 relative overflow-hidden" data-ps="src/components/home/Differentiation.astro:jemmify-works">
        <!-- Decoration -->
        <div class="absolute top-0 right-0 w-32 h-32 bg-emerald/10 blur-3xl rounded-full" data-ps="src/components/home/Differentiation.astro:decoration"></div>
        
        <h3 class="text-2xl font-bold text-emerald mb-8 uppercase tracking-wider relative z-10" data-ps="src/components/home/Differentiation.astro:jemmify-title">Jemmify Works</h3>
        <ul class="space-y-6 relative z-10" data-ps="src/components/home/Differentiation.astro:jemmify-list">
          {[
            "Conversion-centered custom design",
            "Focus on business outcomes and growth",
            "Strategy-first approach",
            "Data-driven decisions",
            "Built for continuous optimization"
          ].map((item, __psIdx) => {
            const highlightedText = item
              .replace(/Conversion/, '<span class="text-emerald" data-ps={`src/components/home/Differentiation.astro:l67tn-${__psIdx}`}>Conversion</span>')
              .replace(/growth/, '<span class="text-emerald" data-ps={`src/components/home/Differentiation.astro:l67tm-${__psIdx}`}>growth</span>');
            return (
            <li class="flex items-start gap-4 text-zinc-100" data-ps="src/components/home/Differentiation.astro:jemmify-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
              <span class="text-lg font-medium" data-ps="src/components/home/Differentiation.astro:jemmify-text" set:html={highlightedText}></span>
            </li>
          )})}
        </ul>
      </div>
    </div>

    <!-- Statement Block -->
    <div class="text-center mb-24 reveal" data-ps="src/components/home/Differentiation.astro:statement">
      <blockquote class="text-3xl md:text-4xl font-bold text-zinc-900 max-w-4xl mx-auto leading-tight italic" data-ps="src/components/home/Differentiation.astro:quote">
        “If your website isn’t generating <span class="text-ruby font-extrabold" data-ps="src/components/home/Differentiation.astro:l67tl">leads</span> or <span class="text-ruby font-extrabold" data-ps="src/components/home/Differentiation.astro:l67tk">revenue</span>, it’s not doing its job.”
      </blockquote>
    </div>

    <!-- Differentiation Pillars -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-24" data-ps="src/components/home/Differentiation.astro:pillars">
      {[
        {
          title: "Strategy First",
          description: "We align every website with clear business goals before designing anything.",
          icon: "target"
        },
        {
          title: "Conversion-Centered Design",
          description: "Every element is designed to drive action and improve conversions.",
          icon: "mouse-pointer-click"
        },
        {
          title: "Data-Driven Execution",
          description: "We use analytics, user behavior, and insights to guide decisions.",
          icon: "bar-chart-3"
        },
        {
          title: "Built for ROI",
          description: "Our goal is to deliver measurable results, aiming for up to 3X ROI within 6–12 months.",
          icon: "trending-up"
        }
      ].map((pillar, index) => {
        let hoverColor = "group-hover:bg-sapphire";
        let borderColor = "hover:border-sapphire/30";
        if (pillar.title === "Conversion-Centered Design") {
          hoverColor = "group-hover:bg-ruby";
          borderColor = "hover:border-ruby/30";
        } else if (pillar.title === "Built for ROI") {
          hoverColor = "group-hover:bg-emerald";
          borderColor = "hover:border-emerald/30";
        }
        return (
        <div class={`reveal p-8 bg-white border border-zinc-200 rounded-3xl transition-all duration-300 group ${borderColor}`} style={`transition-delay: ${index * 100}ms`} data-ps="src/components/home/Differentiation.astro:pillar">
          <div class={`w-12 h-12 bg-primary text-white rounded-xl flex items-center justify-center mb-6 transition-colors ${hoverColor}`} data-ps="src/components/home/Differentiation.astro:pillar-icon">
             {pillar.icon === 'target' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>}
             {pillar.icon === 'mouse-pointer-click' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 9 5 12 1.774-5.226L21 14Z"/><path d="m16.071 16.071 4.243 4.243"/></svg>}
             {pillar.icon === 'bar-chart-3' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>}
             {pillar.icon === 'trending-up' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>}
          </div>
          <h3 class="text-xl font-bold text-zinc-900 mb-3" data-ps="src/components/home/Differentiation.astro:pillar-title">{pillar.title}</h3>
          <p class="text-zinc-600 leading-relaxed" data-ps="src/components/home/Differentiation.astro:pillar-desc">{pillar.description}</p>
        </div>
      )})}
    </div>

    <!-- CTA Block -->
    <div class="reveal reveal-delay-2 p-12 md:p-16 bg-primary rounded-[2.5rem] text-center relative overflow-hidden group" data-ps="src/components/home/Differentiation.astro:cta">
      <!-- Decoration -->
      <div class="absolute -top-24 -left-24 w-64 h-64 bg-ruby/10 blur-[100px] rounded-full group-hover:bg-ruby/20 transition-all duration-700" data-ps="src/components/home/Differentiation.astro:cta-decoration-1"></div>
      <div class="absolute -bottom-24 -right-24 w-64 h-64 bg-emerald/10 blur-[100px] rounded-full group-hover:bg-emerald/20 transition-all duration-700" data-ps="src/components/home/Differentiation.astro:cta-decoration-2"></div>
      
      <div class="relative z-10" data-ps="src/components/home/Differentiation.astro:cta-content">
        <h3 class="text-3xl md:text-4xl font-bold text-white mb-8" data-ps="src/components/home/Differentiation.astro:cta-title">Ready to turn your website into a <span class="text-emerald" data-ps="src/components/home/Differentiation.astro:l67tj">growth</span> engine?</h3>
        <a href="#contact" class="inline-flex items-center gap-2 px-8 py-4 bg-ruby hover:bg-ruby-dark text-white font-bold rounded-full transition-all duration-300 transform hover:scale-105 shadow-xl shadow-ruby/20" data-ps="src/components/home/Differentiation.astro:cta-button">
          Start Your Evolution
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
