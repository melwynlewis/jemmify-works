---
import { SITE } from '@/config/site';
---

<section id="hero" class="relative pt-32 pb-20 md:pt-48 md:pb-32 px-6 overflow-hidden min-h-[90vh] flex items-center bg-primary" data-ps="src/components/home/Hero.astro:c630f">
  <!-- Background Image with Gradient Accent -->
  <div class="absolute inset-0 z-0" data-ps="src/components/home/Hero.astro:ecxgfa">
    <img 
      src="https://cdn.pagesmith.app/a9746ff4/images/a-high-end-contemporary-dark-website-background-featuring-su-001d-1024.webp"
      srcset="https://cdn.pagesmith.app/a9746ff4/images/a-high-end-contemporary-dark-website-background-featuring-su-001d-1024.webp 1024w, https://cdn.pagesmith.app/a9746ff4/images/a-high-end-contemporary-dark-website-background-featuring-su-001d-768.webp 768w, https://cdn.pagesmith.app/a9746ff4/images/a-high-end-contemporary-dark-website-background-featuring-su-001d-640.webp 640w, https://cdn.pagesmith.app/a9746ff4/images/a-high-end-contemporary-dark-website-background-featuring-su-001d-320.webp 320w"
      sizes="100vw"
      alt="Subtle abstract background featuring revenue growth charts and graphs in a dark professional theme"
      class="w-full h-full object-cover opacity-30 mix-blend-overlay"
      loading="eager" data-ps="src/components/home/Hero.astro:fibi7z" />
    <div class="absolute inset-0 bg-primary/80" data-ps="src/components/home/Hero.astro:ecxgfb"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-sapphire/20 blur-[120px] rounded-full translate-x-1/3 -translate-y-1/3 pointer-events-none" data-ps="src/components/home/Hero.astro:ecxgfb"></div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-emerald/20 blur-[100px] rounded-full -translate-x-1/3 translate-y-1/3 pointer-events-none" data-ps="src/components/home/Hero.astro:ecxgfc"></div>
  </div>

  <div class="max-w-5xl mx-auto text-center relative z-10" data-ps="src/components/home/Hero.astro:ecxgfc">
    <div class="inline-block px-4 py-1.5 bg-white/5 backdrop-blur-md border border-white/10 rounded-full text-zinc-300 text-sm font-semibold mb-8 hero-animate" data-ps="src/components/home/Hero.astro:badge">
      Built for ambitious businesses in Bengaluru & beyond
    </div>
    
    <h1 class="hero-animate hero-animate-delay-1 text-[clamp(2.5rem,8vw,5rem)] font-bold mb-8 text-white leading-[1.1] tracking-tight drop-shadow-xl" data-ps="src/components/home/Hero.astro:p3vdzm">
      We Don’t Just Build Websites.<br />
      We Build <span class="text-ruby" data-ps="src/components/home/Hero.astro:3f6ipc">Revenue</span> Engines.
    </h1>
    
    <p class="hero-animate hero-animate-delay-2 text-xl md:text-2xl mb-12 max-w-3xl mx-auto text-zinc-300 leading-relaxed font-light" data-ps="src/components/home/Hero.astro:ijv6zd">
      We design high-performance websites that generate leads, improve conversions, and drive measurable business growth for ambitious businesses in Bengaluru and beyond.
    </p>
    
    <div class="hero-animate hero-animate-delay-3 flex flex-col items-center" data-ps="src/components/home/Hero.astro:actions">
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-6 w-full" data-ps="src/components/home/Hero.astro:ecxgfc">
        <a href="#contact" class="inline-block px-10 py-5 rounded-xl font-bold bg-ruby text-white hover:bg-ruby-dark transition-all hover-lift text-lg shadow-lg shadow-ruby/20" data-ps="src/components/home/Hero.astro:iblyyl">
          Start Your Project
        </a>
        <a href="#audit" class="inline-block px-10 py-5 rounded-xl font-bold bg-transparent text-white border-2 border-white/20 hover:bg-white/10 transition-all hover-lift text-lg" data-ps="src/components/home/Hero.astro:iblyyl2">
          Get a Free Website Audit
        </a>
      </div>
      <p class="text-zinc-400 text-sm font-medium tracking-wide" data-ps="src/components/home/Hero.astro:trustline">
        Average results: <span class="text-emerald font-bold" data-ps="src/components/home/Hero.astro:3f6ipc">2–4×</span> increase in conversions within the first year.
      </p>
    </div>
  </div>
</section>
