---
// Contact section with form
---

<section id="contact" class="py-24 bg-gradient-to-br from-primary to-[#2a2a2a] text-white px-6 relative overflow-hidden" data-ps="src/components/home/Contact.astro:hfh231">
  <div class="absolute inset-0 z-0 bg-sapphire/5" data-ps="src/components/home/Contact.astro:bg-overlay"></div>
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center relative z-10" data-ps="src/components/home/Contact.astro:o1wuze">
    <div class="reveal" data-ps="src/components/home/Contact.astro:o1wuzd">
      <h2 class="text-4xl md:text-6xl font-bold mb-8 leading-tight" data-ps="src/components/home/Contact.astro:hp7u2k">Start Your <span class="text-zinc-400" data-ps="src/components/home/Contact.astro:jamztr">Evolution Today.</span></h2>
      <p class="text-xl text-zinc-400 mb-12 max-w-lg leading-relaxed" data-ps="src/components/home/Contact.astro:u4l0aw">
        Let's discuss how we can help your business evolve into a market leader. Our team is ready to build your strategy.
      </p>
      
      <div class="space-y-8" data-ps="src/components/home/Contact.astro:o1wuzc">
        <div class="flex gap-6 items-center" data-ps="src/components/home/Contact.astro:o1wuzb">
          <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-sapphire" data-ps="src/components/home/Contact.astro:o1wuza">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
          <div data-ps="src/components/home/Contact.astro:phone-info">
            <h4 class="font-bold text-lg" data-ps="src/components/home/Contact.astro:phone-label">Phone</h4>
            <a href="tel:+919035727878" class="text-zinc-400 hover:text-[#bcc341] transition-colors" data-ps="src/components/home/Contact.astro:phone-value">+91 90357 27878</a>
          </div>
        </div>
        <div class="flex gap-6 items-center" data-ps="src/components/home/Contact.astro:o1wuzb">
          <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-sapphire" data-ps="src/components/home/Contact.astro:o1wuza">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <div data-ps="src/components/home/Contact.astro:o1wuz9">
            <h4 class="font-bold text-lg" data-ps="src/components/home/Contact.astro:bnm0cm">Email Us</h4>
            <p class="text-zinc-400" data-ps="src/components/home/Contact.astro:u4l0ax">hello@jemmify.works</p>
          </div>
        </div>
        <div class="flex gap-6 items-center" data-ps="src/components/home/Contact.astro:1ijz25">
          <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-sapphire" data-ps="src/components/home/Contact.astro:1ijz26">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <div data-ps="src/components/home/Contact.astro:1ijz27">
            <h4 class="font-bold text-lg" data-ps="src/components/home/Contact.astro:bnm0cl">Location</h4>
            <p class="text-zinc-400" data-ps="src/components/home/Contact.astro:u4l0ay">Bengaluru, KA, India</p>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-primary p-8 md:p-12 rounded-[2.5rem] border border-white/10 shadow-2xl reveal reveal-delay-1" data-ps="src/components/home/Contact.astro:1ijz28">
      <div id="contact-status" class="hidden mb-6 px-4 py-3 rounded-lg" data-ps="src/components/home/Contact.astro:1ijz29"></div>
      
      <form id="contact-form" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-ps="src/components/home/Contact.astro:1ijz2a">
          <div data-ps="src/components/home/Contact.astro:1ijz2b">
            <label for="name" class="block text-sm font-bold text-zinc-400 uppercase tracking-wider mb-2" data-ps="src/components/home/Contact.astro:lknwai">Name</label>
            <input type="text" id="name" name="name" required placeholder="John Doe"
              class="w-full bg-black/30 border border-white/10 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-sapphire focus:border-transparent transition-all" />
          </div>
          <div data-ps="src/components/home/Contact.astro:1ijz2c">
            <label for="email" class="block text-sm font-bold text-zinc-400 uppercase tracking-wider mb-2" data-ps="src/components/home/Contact.astro:lknwaj">Email</label>
            <input type="email" id="email" name="email" required placeholder="john@example.com"
              class="w-full bg-black/30 border border-white/10 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-sapphire focus:border-transparent transition-all" />
          </div>
        </div>
        <div data-ps="src/components/home/Contact.astro:1ijz2e">
          <label for="phone" class="block text-sm font-bold text-zinc-400 uppercase tracking-wider mb-2" data-ps="src/components/home/Contact.astro:lknwak">Phone Number</label>
          <input type="tel" id="phone" name="phone" required placeholder="+91 98765 43210"
            class="w-full bg-black/30 border border-white/10 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-sapphire focus:border-transparent transition-all" />
        </div>
        <div data-ps="src/components/home/Contact.astro:1ijz2d">
          <label for="subject" class="block text-sm font-bold text-zinc-400 uppercase tracking-wider mb-2" data-ps="src/components/home/Contact.astro:lknwal">How can we help?</label>
          <select id="subject" name="subject" class="w-full bg-black/30 border border-white/10 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-sapphire focus:border-transparent transition-all">
            <option>Web & Digital Experience</option>
            <option>Brand Identity</option>
            <option>Growth Strategy</option>
            <option>General Inquiry</option>
          </select>
        </div>
        <div data-ps="src/components/home/Contact.astro:1ijz2e">
          <label for="message" class="block text-sm font-bold text-zinc-400 uppercase tracking-wider mb-2" data-ps="src/components/home/Contact.astro:lknwam">Message</label>
          <textarea id="message" name="message" rows="4" required placeholder="Tell us about your project..."
            class="w-full bg-black/30 border border-white/10 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-sapphire focus:border-transparent transition-all"></textarea>
        </div>
        <button type="submit" id="contact-submit"
          class="w-full bg-ruby text-white font-bold py-4 rounded-xl hover:bg-ruby-dark transition-all hover-lift text-lg shadow-lg shadow-ruby/20" data-ps="src/components/home/Contact.astro:don7rn">
          Send Message
        </button>
      </form>
    </div>
  </div>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const status = document.getElementById('contact-status') as HTMLDivElement;
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      const formData = new FormData(form);

      try {
        const response = await fetch('/psapi-internal-v1/forms/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: formData.get('name'),
            email: formData.get('email'),
            phone: formData.get('phone'),
            subject: formData.get('subject'),
            message: formData.get('message'),
          }),
        });

        const result = await response.json();

        if (result.success) {
          status.className = 'mb-6 px-4 py-3 rounded-lg bg-green-500/10 border border-green-500/20 text-green-500';
          status.textContent = 'Thank you! Your message has been sent.';
          form.reset();
        } else {
          throw new Error(result.error || 'Failed to send');
        }
      } catch (err) {
        status.className = 'mb-6 px-4 py-3 rounded-lg bg-red-500/10 border border-red-500/20 text-red-500';
        status.textContent = 'Failed to send. Please try again later.';
      } finally {
        status.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message';
      }
    });
  </script>
</section>
