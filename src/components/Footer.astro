---
import { SITE } from '@/config/site';
---

<footer class="bg-black text-white py-20 px-6 border-t border-zinc-800" data-ps="src/components/Footer.astro:ikmf32">
  <div class="max-w-7xl mx-auto" data-ps="src/components/Footer.astro:p4vf87">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16" data-ps="src/components/Footer.astro:p4vf88">
      <!-- Logo & Desc -->
      <div class="md:col-span-2" data-ps="src/components/Footer.astro:p4vf89">
        <img src="https://cdn.pagesmith.app/a9746ff4/images/Jemmify-Works-Logo-Reversed-Final-1024.webp" alt="Jemmify Works" class="h-12 w-auto mb-6" data-ps="src/components/Footer.astro:4qdjey" />
        <p class="text-zinc-400 max-w-sm leading-relaxed" data-ps="src/components/Footer.astro:euok">
          We help ambitious businesses in Bengaluru and beyond turn their websites into growth engines through data-driven strategies.
        </p>
      </div>

      <!-- Links 1 -->
      <div data-ps="src/components/Footer.astro:p4vf8a">
        <h3 class="text-sm font-bold uppercase tracking-wider text-zinc-500 mb-6" data-ps="src/components/Footer.astro:f0091f">Solutions</h3>
        <ul class="list-none p-0 m-0 flex flex-col gap-3">
          <li data-ps="src/components/Footer.astro:wyji7d"><a href="/#services" class="text-zinc-400 hover:text-white transition-colors no-underline" data-ps="src/components/Footer.astro:8o2pe">Web & Digital</a></li>
          <li data-ps="src/components/Footer.astro:wyji7e"><a href="/#services" class="text-zinc-400 hover:text-white transition-colors no-underline" data-ps="src/components/Footer.astro:8o2pf">Brand Identity</a></li>
          <li data-ps="src/components/Footer.astro:wyji7f"><a href="/#services" class="text-zinc-400 hover:text-white transition-colors no-underline" data-ps="src/components/Footer.astro:8o2pg">Growth Strategy</a></li>
        </ul>
      </div>

      <!-- Links 2 -->
      <div data-ps="src/components/Footer.astro:p4vf8b">
        <h3 class="text-sm font-bold uppercase tracking-wider text-zinc-500 mb-6" data-ps="src/components/Footer.astro:f0091g">Contact</h3>
        <ul class="list-none p-0 m-0 flex flex-col gap-3">
          <li data-ps="src/components/Footer.astro:wyji7g"><a href="tel:+919035727878" class="text-zinc-400 hover:text-[#bcc341] transition-colors no-underline" data-ps="src/components/Footer.astro:phone-link">+91 90357 27878</a></li>
          <li data-ps="src/components/Footer.astro:wyji7h"><a href="mailto:hello@jemmify.works" class="text-zinc-400 hover:text-white transition-colors no-underline" data-ps="src/components/Footer.astro:8o2ph">hello@jemmify.com</a></li>
          <li class="flex gap-4 mt-2" data-ps="src/components/Footer.astro:wyji7i">
            <a href={SITE.socials.linkedin} aria-label="LinkedIn" class="text-zinc-400 hover:text-white transition-colors" data-ps="src/components/Footer.astro:8o2pi"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg></a>
            <a href={SITE.socials.twitter} aria-label="Twitter" class="text-zinc-400 hover:text-white transition-colors" data-ps="src/components/Footer.astro:8o2pj"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg></a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-zinc-900 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-zinc-500 text-sm" data-ps="src/components/Footer.astro:p4vf8b">
      <p data-ps="src/components/Footer.astro:euol">© {new Date().getFullYear()} {SITE.name}. All rights reserved.</p>
      <div class="flex gap-6" data-ps="src/components/Footer.astro:p4vf8b">
        <a href="/privacy" class="hover:text-white transition-colors no-underline" data-ps="src/components/Footer.astro:8o2pk">Privacy Policy</a>
        <a href="/terms" class="hover:text-white transition-colors no-underline" data-ps="src/components/Footer.astro:8o2pl">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
